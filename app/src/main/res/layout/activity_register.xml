<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:orientation="vertical"
        android:padding="30dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Tạo tài khoản"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Điền thông tin bên dưới để bắt đầu mua sắm"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginBottom="30dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText android:id="@+id/edtUsername" android:hint="Username"
            android:background="@drawable/edit_text_bg" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="12dp"/>

        <EditText android:id="@+id/edtPassword" android:hint="Password" android:inputType="textPassword"
            android:background="@drawable/edit_text_bg" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="12dp"/>

        <EditText android:id="@+id/edtConfirm" android:hint="Xác nhận mật khẩu" android:inputType="textPassword"
            android:background="@drawable/edit_text_bg" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="12dp"/>

        <EditText android:id="@+id/edtFullname" android:hint="Họ và tên"
            android:background="@drawable/edit_text_bg" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="12dp"/>

        <EditText android:id="@+id/edtEmail" android:hint="Email" android:inputType="textEmailAddress"
            android:background="@drawable/edit_text_bg" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="12dp"/>

        <EditText android:id="@+id/edtPhone" android:hint="Số điện thoại" android:inputType="phone"
            android:background="@drawable/edit_text_bg" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="12dp"/>

        <EditText android:id="@+id/edtAddress" android:hint="Địa chỉ nhận hàng"
            android:background="@drawable/edit_text_bg" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="30dp"/>

        <android.widget.Button
            android:id="@+id/btnRegister"
            android:text="Đăng ký tài khoản"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/button_bg"
            android:layout_width="match_parent"
            android:layout_height="55dp"/>

    </LinearLayout>
</ScrollView>